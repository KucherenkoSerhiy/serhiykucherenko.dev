---
import '../styles/global.css';
import Icon from '../components/Icon.astro';
import { SITE_TITLE, SITE_URL, SITE_DESCRIPTION, GITHUB_URL, LINKEDIN_URL, EMAIL } from '../consts';

interface Props {
  title?: string;
  description?: string;
  canonicalUrl?: string;
  type?: string;
}

const { title, description = SITE_DESCRIPTION, canonicalUrl, type = 'website' } = Astro.props;
const pageTitle = title ? `${title} · ${SITE_TITLE}` : SITE_TITLE;
const canonical = canonicalUrl ?? new URL(Astro.url.pathname, SITE_URL).href;
const path = Astro.url.pathname;
const nav = [
  { href: '/blog/', label: 'blog', icon: 'blog' },
  { href: '/lab/', label: 'lab', icon: 'lab' },
  { href: '/build/', label: 'build', icon: 'build' },
  { href: '/contact/', label: 'contact', icon: 'contact' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="alternate" type="application/rss+xml" title={SITE_TITLE} href="/rss.xml" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <meta name="theme-color" content="#0c0e11" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content={type} />
    <meta property="og:url" content={new URL(Astro.url.pathname, SITE_URL).href} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:image" content={new URL('/og.png', SITE_URL).href} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL('/og.png', SITE_URL).href} />
    <slot name="head" />
    <script is:inline>
      if (localStorage.getItem('theme') === 'light') document.documentElement.dataset.theme = 'light';
    </script>
  </head>
  <body>
    <header class="site">
      <a class="brand" href="/">serhiykucherenko.dev</a>
      <nav>
        {
          nav.map((n) => (
            <a href={n.href} aria-current={path.startsWith(n.href) ? 'page' : undefined}>
              <Icon name={n.icon} size={14} />
              {n.label}
            </a>
          ))
        }
        <button id="theme-toggle" aria-label="Toggle light mode"><Icon name="theme" size={15} /></button>
      </nav>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      <span class="open"><span class="open-dot" aria-hidden="true"></span>open to freelance</span>
      <span class="sep" aria-hidden="true">|</span>
      <a href={GITHUB_URL}><Icon name="github" size={13} />github</a>
      <a href={LINKEDIN_URL}>linkedin</a>
      <a href={`mailto:${EMAIL}`}>email</a>
      <a href="/rss.xml"><Icon name="rss" size={13} />rss</a>
      <span class="built" aria-hidden="true">built static · 0 trackers</span>
    </footer>
    <script is:inline>
      document.getElementById('theme-toggle').addEventListener('click', () => {
        const root = document.documentElement;
        const next = root.dataset.theme === 'light' ? 'dark' : 'light';
        if (next === 'light') root.dataset.theme = 'light';
        else delete root.dataset.theme;
        localStorage.setItem('theme', next);
      });
    </script>
  </body>
</html>
