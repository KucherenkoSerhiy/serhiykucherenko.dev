---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Base>
  <h1>Serhiy Kucherenko</h1>
  <p>
    Senior fullstack engineer, 9 years across banking infrastructure, travel and invoicing,
    medical, and industrial domains. Currently building AI systems from scratch: evals,
    citations, all of it.
  </p>
  <p>I write about what I build and what breaks along the way.</p>
  <p>Open to freelance work on RAG systems, LLM cost control, and backend .NET.</p>

  <h2>Latest writing</h2>
  <ul class="plain post-list">
    {
      posts.map((post) => (
        <li>
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          <span class="meta">
            {post.data.pubDate.toISOString().slice(0, 10)} · {post.data.description}
          </span>
        </li>
      ))
    }
  </ul>
  <p><a href="/blog/">All posts →</a> · <a href="/projects/">Projects →</a></p>
</Base>
