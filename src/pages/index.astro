---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Base>
  <script
    type="application/ld+json"
    slot="head"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Serhiy Kucherenko',
      url: 'https://serhiykucherenko.dev',
      jobTitle: 'Senior fullstack engineer',
      knowsAbout: ['RAG systems', 'LLM evaluation', 'SEPA payments', 'ISO 20022', '.NET', 'Python'],
      sameAs: ['https://github.com/KucherenkoSerhiy'],
    })}
  />
  <section class="hero">
    <canvas id="field" aria-hidden="true"></canvas>
    <div class="hero-inner">
      <h1 class="sr-only">Serhiy Kucherenko — fullstack engineer building AI systems</h1>
      <pre class="log" id="log"><span class="p">$ serhiy --status</span>
engineer   fullstack, 9y: banking · travel · medical · industrial
now        building AI systems from scratch: evals, citations, all of it
<span class="ok">shipped</span>    <a href="https://github.com/KucherenkoSerhiy/payments-rag">payments-rag</a> — rag over SEPA rulebooks, page-cited
<span class="amber">scoping</span>    llm-cost-gateway — caching · spend tracking · alerts<span class="cursor" aria-hidden="true"></span></pre>
      <div class="doors">
        <a class="door" href="/hire/">
          <span class="cmd">&gt; hire --freelance</span>
          <span class="sub">rag systems · llm cost control · backend .net</span>
        </a>
        <a class="door" href="/lab/">
          <span class="cmd">&gt; cd lab/</span>
          <span class="sub">experiments, demos, things that fizz</span>
        </a>
      </div>
    </div>
  </section>

  <h2>Latest writing</h2>
  {
    posts[0] && (
      <a class="featured" href={`/blog/${posts[0].id}/`}>
        <span class="featured-metric">{posts[0].data.metric ?? posts[0].data.description}</span>
        <span class="featured-title">{posts[0].data.title}</span>
        <span class="meta">{posts[0].data.pubDate.toISOString().slice(0, 10)}</span>
      </a>
    )
  }
  <ul class="plain post-list">
    {
      posts.slice(1).map((post) => (
        <li>
          <a href={`/blog/${post.id}/`}>{post.data.title}</a>
          <span class="meta">
            <span>{post.data.pubDate.toISOString().slice(0, 10)}</span>
            {post.data.metric && <span class="n">{post.data.metric}</span>}
          </span>
        </li>
      ))
    }
  </ul>
  <p class="meta"><a href="/blog/">all posts →</a></p>
</Base>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }
</style>

<script is:inline>
  (() => {
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;

    // Boot: reveal log lines one by one. Content is real HTML; JS only paces it.
    const log = document.getElementById('log');
    if (log && !reduced) {
      const lines = log.innerHTML.split('\n');
      let i = 0;
      log.innerHTML = '';
      log.style.minHeight = lines.length * 1.65 + 'em';
      const step = () => {
        if (i >= lines.length) return;
        log.innerHTML = lines.slice(0, ++i).join('\n');
        setTimeout(step, 110);
      };
      step();
    }

    // Glyph field: dim characters that wake near the cursor.
    const canvas = document.getElementById('field');
    const hero = canvas && canvas.parentElement;
    if (!canvas || !hero) return;
    const ctx = canvas.getContext('2d');
    const CHARS = '01<>{}[]:.·pacs008AT41sepa'.split('');
    const cell = 22;
    let glyphs = [];
    let mx = -9999, my = -9999, raf;
    const resize = () => {
      canvas.width = hero.clientWidth;
      canvas.height = hero.clientHeight;
      glyphs = [];
      for (let r = 0; r < Math.ceil(canvas.height / cell); r++)
        for (let c = 0; c < Math.ceil(canvas.width / cell); c++)
          glyphs.push({ x: c * cell + 6, y: r * cell + 16, ch: CHARS[(Math.random() * CHARS.length) | 0] });
    };
    resize();
    addEventListener('resize', resize);
    const accent = () => getComputedStyle(document.documentElement).getPropertyValue('--accent').trim();
    const dim = () => getComputedStyle(document.documentElement).getPropertyValue('--dim').trim();
    const draw = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.font = '13px ui-monospace, Consolas, monospace';
      const near = accent(), far = dim();
      for (const g of glyphs) {
        const d = Math.hypot(g.x - mx, g.y - my);
        ctx.globalAlpha = Math.max(0.05, 0.5 - d / 260);
        ctx.fillStyle = d < 130 ? near : far;
        ctx.fillText(g.ch, g.x, g.y);
        if (!reduced && d < 130 && Math.random() < 0.03) g.ch = CHARS[(Math.random() * CHARS.length) | 0];
      }
      ctx.globalAlpha = 1;
    };
    draw();
    hero.addEventListener('pointermove', (e) => {
      const b = hero.getBoundingClientRect();
      mx = e.clientX - b.left;
      my = e.clientY - b.top;
      if (!raf) raf = requestAnimationFrame(() => { raf = 0; draw(); });
    });
    hero.addEventListener('pointerleave', () => {
      mx = my = -9999;
      draw();
    });
  })();
</script>
