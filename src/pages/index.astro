---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latest = posts[0];
const parts = (latest?.data.metric ?? '').split('→').map((s) => s.trim());
---

<Base>
  <script
    type="application/ld+json"
    slot="head"
    is:inline
    set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Person',
      name: 'Serhiy Kucherenko',
      url: 'https://serhiykucherenko.dev',
      jobTitle: 'Senior fullstack engineer',
      knowsAbout: ['RAG systems', 'LLM evaluation', 'SEPA payments', 'ISO 20022', '.NET', 'Python'],
      sameAs: ['https://github.com/KucherenkoSerhiy'],
    })}
  />

  <section class="hero">
    <canvas id="field" aria-hidden="true"></canvas>
    <div class="hero-inner">
      <h1 class="sr-only">Serhiy Kucherenko — fullstack engineer building AI systems from scratch</h1>

      <p class="eyebrow">fig.0 — the operator</p>
      <div class="opmap">
        <div class="op-node">
          <div class="t">.NET / banking</div>
          <div class="s">9y · SEPA · ISO 20022</div>
        </div>
        <div class="op-link"></div>
        <div class="op-node now">
          <div class="t">AI systems, from scratch</div>
          <div class="s">rag · evals · citations · cost</div>
        </div>
        <div class="op-link"></div>
        <div class="op-node next">
          <div class="t">your system</div>
          <div class="s">open to freelance</div>
        </div>
      </div>

      {
        latest && (
          <>
            <p class="eyebrow" style="margin-top:2rem;">
              latest · {latest.data.pubDate.toISOString().slice(0, 10)}
            </p>
            <a href={`/blog/${latest.id}/`} style="text-decoration:none;">
              <div class="metricline">
                {parts.length === 2 ? (
                  <>
                    <span class="big">{parts[0]}</span>
                    <span class="arrow">→</span>
                    <span class="big ok">{parts[1]}</span>
                  </>
                ) : (
                  <span class="big">{parts[0]}</span>
                )}
              </div>
              <div style="color:var(--fg);margin-top:0.4rem;">
                {latest.data.title} <span style="color:var(--accent)">→</span>
              </div>
            </a>
          </>
        )
      }

      <div class="doors">
        <a class="door" href="/contact/">
          <span class="cmd">&gt; contact --freelance</span>
          <span class="sub">rag · llm cost control · backend .net</span>
        </a>
        <a class="door" href="/lab/">
          <span class="cmd">&gt; cd lab/</span>
          <span class="sub">demos, experiments, things that fizz</span>
        </a>
      </div>
    </div>
  </section>
</Base>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip-path: inset(50%);
    white-space: nowrap;
  }
  .hero-inner .eyebrow:first-of-type {
    margin-top: 0;
  }
</style>

<script is:inline>
  (() => {
    const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
    const canvas = document.getElementById('field');
    const hero = canvas && canvas.parentElement;
    if (!canvas || !hero) return;
    const ctx = canvas.getContext('2d');
    const CHARS = '01<>{}[]:.·pacs008AT41sepa'.split('');
    const cell = 22;
    let glyphs = [];
    let mx = -9999, my = -9999, raf;
    const resize = () => {
      canvas.width = hero.clientWidth;
      canvas.height = hero.clientHeight;
      glyphs = [];
      for (let r = 0; r < Math.ceil(canvas.height / cell); r++)
        for (let c = 0; c < Math.ceil(canvas.width / cell); c++)
          glyphs.push({ x: c * cell + 6, y: r * cell + 16, ch: CHARS[(Math.random() * CHARS.length) | 0] });
    };
    resize();
    addEventListener('resize', resize);
    const accent = () => getComputedStyle(document.documentElement).getPropertyValue('--accent').trim();
    const dim = () => getComputedStyle(document.documentElement).getPropertyValue('--dim').trim();
    const draw = () => {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.font = '13px ui-monospace, Consolas, monospace';
      const near = accent(), far = dim();
      for (const g of glyphs) {
        const d = Math.hypot(g.x - mx, g.y - my);
        ctx.globalAlpha = Math.max(0.05, 0.5 - d / 260);
        ctx.fillStyle = d < 130 ? near : far;
        ctx.fillText(g.ch, g.x, g.y);
        if (!reduced && d < 130 && Math.random() < 0.03) g.ch = CHARS[(Math.random() * CHARS.length) | 0];
      }
      ctx.globalAlpha = 1;
    };
    draw();
    hero.addEventListener('pointermove', (e) => {
      const b = hero.getBoundingClientRect();
      mx = e.clientX - b.left;
      my = e.clientY - b.top;
      if (!raf) raf = requestAnimationFrame(() => { raf = 0; draw(); });
    });
    hero.addEventListener('pointerleave', () => { mx = my = -9999; draw(); });
  })();
</script>
