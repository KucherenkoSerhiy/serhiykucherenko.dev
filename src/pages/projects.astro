---
import Base from '../layouts/Base.astro';
---

<Base title="Projects" description="Open-source projects by Serhiy Kucherenko: RAG systems, LLM tooling.">
  <h1>Projects</h1>

  <div class="card">
    <h2>payments-rag</h2>
    <p class="stack">Python · Postgres + pgvector · Claude API · Docker</p>
    <p>
      From-scratch RAG over SEPA payment rulebooks. Ask a question in plain English, get a
      short answer with page-level citations into the actual spec. No LangChain: raw API
      calls, a hand-rolled retriever, and a cross-model LLM-as-judge eval harness that keeps
      the answers honest.
    </p>
    <p>
      <a href="https://github.com/KucherenkoSerhiy/payments-rag">GitHub</a>
      <!-- TODO: add live demo URL once the deployment lands -->
    </p>
  </div>

  <div class="card">
    <h2>LLM Cost Gateway</h2>
    <p class="stack">WIP</p>
    <p>
      A gateway between apps and LLM providers that adds semantic caching, spend tracking,
      budget alerts, and provider abstraction. Scoping phase.
    </p>
  </div>
</Base>
